# Environment Configuration - Backend

# MongoDB Connection String
MONGO_URL=mongodb+srv://<username>:<password>@cluster.mongodb.net/
DB_NAME=eventa

# Server Port
PORT=8000

# Authentication Secrets
# ADMIN_SECRET is used for the master admin login (MUST be changed in production)
ADMIN_SECRET=your_super_strong_random_admin_password
# JWT_SECRET is used to sign tokens (defaults to ADMIN_SECRET if not set)
JWT_SECRET=your_super_strong_random_jwt_secret

# Security Settings
# Comma-separated list of allowed origins. Set to specific domains in production.
CORS_ORIGINS=https://eventa.in,https://www.eventa.in

# OpenAI API Key (Required for AI summarization features)
OPENAI_API_KEY=sk-proj-...

# Optional: Set this to 'true' in Render to enable production security checks
RENDER=true
